#!/usr/bin/env bash
set -euo pipefail

mapfile -d '' -t STAGED_PHP_FILES < <(
  git diff --cached --name-only --diff-filter=ACMR -z | grep -z -E '\.php$' || true
)

if [ ${#STAGED_PHP_FILES[@]} -eq 0 ]; then
  exit 0
fi

echo "Running Pint on staged PHP files..."
XDEBUG_MODE=off vendor/bin/pint "${STAGED_PHP_FILES[@]}"

# Fail if Pint changed any of the staged files.
if ! git diff --quiet -- "${STAGED_PHP_FILES[@]}"; then
  echo "Pint modified staged files. Please review, stage, and retry commit."
  exit 1
fi
